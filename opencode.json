{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM (OpenAI-compatible)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "default": {
          "name": "default",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    },
    "1bitai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "1bit AI",
      "options": {
        "baseURL": "http://127.0.0.1:18765/v1",
        "apiKey": "local-proxy"
      },
      "models": {
        "qwen3-coder": {
          "name": "qwen3-coder",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "qwen3.5-35b": {
          "name": "qwen3.5-35b",
          "tool_call": true,
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "1bitai/qwen3-coder",
  "small_model": "1bitai/qwen3-coder",
  "default_agent": "1c-analyst",
  "mcp": {
    "onec-data": {
      "type": "local",
      "command": ["mcp/.venv/Scripts/python.exe", "mcp/server.py"],
      "enabled": true,
      "environment": {}
    }
  },
  "permission": {
    "edit": "deny",
    "write": "deny",
    "apply_patch": "deny",
    "bash": {
      "*": "deny"
    },
    "onec-data_*": "allow",
    "skill": "allow",
    "question": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow"
  },
  "agent": {
    "1c-analyst": {
      "mode": "primary",
      "model": "1bitai/qwen3-coder",
      "description": "Аналитик 1С: расследование ошибок пользователей через read-only запросы к базе",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "onec-data_*": "allow",
        "skill": "allow",
        "question": "allow"
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    "WELCOME.md"
  ]
}
